# Copy this file to .env and fill in your values

# Password for the /admin submissions page
form_password=your_password_here

# Netlify API credentials — required to load form submissions on /admin
# Get your personal access token: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_API_TOKEN=your_netlify_personal_access_token

# Your site ID — Netlify: Site Settings > General > Site details > Site ID
NETLIFY_SITE_ID=your_netlify_site_id
